{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**/*.ts", "**/*.js", "**/*.mjs", "**/*.json", "**/*.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"lineEnding": "lf"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["dist/**", "public/**", "node_modules/**", "uploads/**"],
			"linter": { "enabled": false },
			"formatter": { "enabled": false }
		}
	]
}
