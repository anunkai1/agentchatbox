{
  "name": "agentchatbox",
  "version": "0.1.0",
  "private": true,
  "description": "Web chat interface for the pi coding agent. Run the pi agent in your browser, with files, images, and voice notes.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "watch:client": "node scripts/build-client.mjs --watch",
    "build:server": "tsc -p tsconfig.json",
    "build": "npm run build:client && npm run build:server",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "node scripts/build-client.mjs --watch",
    "dev": "concurrently -n server,client -c cyan,green \"npm:dev:server\" \"npm:dev:client\"",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "clean": "rm -rf dist public/app.js public/app.js.map"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.75.3",
    "@earendil-works/pi-ai": "^0.75.3",
    "@earendil-works/pi-tui": "^0.75.3",
    "@earendil-works/pi-web-ui": "^0.75.3",
    "@mariozechner/mini-lit": "^0.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "lit": "^3.3.1",
    "lucide": "^0.544.0",
    "multer": "^2.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
