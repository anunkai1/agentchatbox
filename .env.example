# agentchatbox configuration
#
# Copy to .env and fill in the providers you want to use. Anything left blank
# is simply not exposed to the client.

# Server
PORT=3000
HOST=0.0.0.0
UPLOADS_DIR=./uploads
MAX_UPLOAD_BYTES=52428800

# pi subprocess — the server spawns `pi --mode rpc` per WS connection.
# PI_BIN defaults to "pi" (resolved via $PATH). Override only for tests.
# PI_CWD defaults to process.cwd() at boot. Override to scope pi's sessions.
#PI_BIN=pi
#PI_CWD=

# Voice / TTS / STT
# Python binary for Piper (TTS) and faster-whisper (STT). Defaults to python3.
#PYTHON_BIN=python3
# Piper voice model name. Defaults to en_US-amy-medium.
#PIPER_VOICE=en_US-amy-medium
# Override pi's session directory (where JSONL session files are stored).
# Defaults to ~/.pi/agent/sessions.
#PI_CODING_AGENT_SESSION_DIR=

# LLM provider keys. The names below are the SAME env vars `pi` itself
# reads (see src/server/providers.ts::providerApiKeyEnvVar) — the server
# reads and re-injects each key into the spawned `pi --mode rpc` child, so
# only providers you set a key for appear in the model picker.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
MINIMAX_API_KEY=
HF_TOKEN=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
AI_GATEWAY_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
OPENCODE_API_KEY=

# OPENAI_API_KEY is also used for voice transcription (Whisper).
# If you only need chat, the same key is reused.
